---
const messages = [
  { from: 'user', text: "what's next on the elm st deal?" },
  { from: 'brittani', text: "2 items pending:\n• EMD confirmation due tomorrow\n• 3 email drafts ready for review\nWant me to follow up with title?" },
  { from: 'user', text: "yes" },
  { from: 'brittani', text: "Done. Follow-up sent to Sarah at Premier Title." },
];
---

<div class="mx-auto w-[280px] md:w-[320px]">
  <!-- Phone frame -->
  <div class="relative rounded-[2.5rem] border-[8px] border-slate-800 bg-slate-900 shadow-2xl overflow-hidden">
    <!-- Notch -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-5 bg-slate-800 rounded-b-2xl z-10"></div>

    <!-- Screen -->
    <div class="bg-slate-100 pt-8 pb-4 px-3 min-h-[400px] flex flex-col justify-end">
      <!-- Chat header -->
      <div class="absolute top-8 left-0 right-0 px-4 py-2 bg-white border-b border-slate-200">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center">
            <span class="text-[10px] font-bold text-white">B</span>
          </div>
          <span class="text-xs font-semibold text-slate-900">Brittani AI</span>
          <span class="ml-auto w-2 h-2 rounded-full bg-green-500"></span>
        </div>
      </div>

      <!-- Messages -->
      <div class="space-y-3 mt-10">
        {messages.map((msg) => (
          <div class={`flex ${msg.from === 'user' ? 'justify-end' : 'justify-start'}`}>
            <div class={`max-w-[85%] rounded-2xl px-3 py-2 text-[11px] leading-relaxed whitespace-pre-line ${
              msg.from === 'user'
                ? 'bg-blue-600 text-white rounded-br-md'
                : 'bg-white text-slate-800 border border-slate-200 rounded-bl-md shadow-sm'
            }`}>
              {msg.text}
            </div>
          </div>
        ))}
      </div>

      <!-- Input bar -->
      <div class="mt-3 flex items-center gap-2 bg-white rounded-full border border-slate-200 px-3 py-1.5">
        <div class="flex-1 text-[10px] text-slate-400">iMessage</div>
        <div class="w-5 h-5 rounded-full bg-blue-600 flex items-center justify-center">
          <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

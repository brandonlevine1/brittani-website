---
const currentPath = Astro.url.pathname;

const platformLinks = [
  { label: 'Overview', href: '/platform', description: null },
  { label: 'Contract Intelligence', href: '/platform', description: null },
  { label: 'Communications Engine', href: '/platform', description: null },
  { label: 'Deadline System', href: '/platform', description: null },
  { label: 'Deal Command Center', href: '/platform', description: null },
  { label: 'Integrations', href: '/platform', description: null },
];

const platformFeatured = {
  label: 'Brittani Agent',
  href: '/platform',
  description: 'Your AI-powered transaction coordinator that manages deals end-to-end.',
};

const solutionsLinks = [
  { label: 'For Individual Agents', href: '/solutions/agents' },
  { label: 'For Brokerages', href: '/solutions/brokerages' },
  { label: 'For Teams', href: '/solutions/teams' },
];

const flatLinks = [
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-6 md:px-8 flex items-center justify-between h-18" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Brittani AI Home">
      <img
        src="/images/logo-mark.png"
        alt="Brittani AI"
        width="40"
        height="40"
        class="w-10 h-10 transition-transform duration-200 group-hover:scale-105"
      />
      <span class="text-xl font-bold tracking-tight text-slate-900">
        Brittani<span class="text-[#50BAB4]"> AI</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <!-- Platform Dropdown -->
      <div class="relative group" data-dropdown="platform">
        <button
          type="button"
          class:list={[
            'text-sm font-medium transition-colors duration-200 flex items-center gap-1 dropdown-trigger',
            currentPath.startsWith('/platform')
              ? 'text-blue-600'
              : 'text-slate-600 hover:text-slate-900',
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Platform
          <svg class="w-3.5 h-3.5 transition-transform duration-200 dropdown-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-panel absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible transition-all duration-200 pointer-events-none" role="menu">
          <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 min-w-[320px]">
            <div class="grid gap-1">
              {platformLinks.map(({ label, href }) => (
                <a
                  href={href}
                  class="block px-3 py-2 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors"
                  role="menuitem"
                >
                  {label}
                </a>
              ))}
            </div>
            <!-- Featured: Brittani Agent -->
            <div class="mt-4 pt-4 border-t border-slate-100">
              <a
                href={platformFeatured.href}
                class="block bg-gradient-to-br from-blue-50 to-violet-50 rounded-xl p-4 hover:from-blue-100 hover:to-violet-100 transition-colors"
                role="menuitem"
              >
                <span class="text-sm font-semibold text-slate-900">{platformFeatured.label}</span>
                <span class="block text-xs text-slate-500 mt-1">{platformFeatured.description}</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Solutions Dropdown -->
      <div class="relative group" data-dropdown="solutions">
        <button
          type="button"
          class:list={[
            'text-sm font-medium transition-colors duration-200 flex items-center gap-1 dropdown-trigger',
            currentPath.startsWith('/solutions')
              ? 'text-blue-600'
              : 'text-slate-600 hover:text-slate-900',
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Solutions
          <svg class="w-3.5 h-3.5 transition-transform duration-200 dropdown-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-panel absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible transition-all duration-200 pointer-events-none" role="menu">
          <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 min-w-[280px]">
            <div class="grid gap-1">
              {solutionsLinks.map(({ label, href }) => (
                <a
                  href={href}
                  class="block px-3 py-2 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors"
                  role="menuitem"
                >
                  {label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Flat Links -->
      {flatLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors duration-200',
            currentPath.startsWith(href)
              ? 'text-blue-600'
              : 'text-slate-600 hover:text-slate-900',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Desktop CTAs -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="https://app.brittani.ai/sign-in"
        class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors duration-200 px-4 py-2"
      >
        Log In
      </a>
      <a
        href="https://app.brittani.ai/sign-up"
        class="text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 px-5 py-2.5 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-blue-600/25"
      >
        Request Demo
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -mr-2 text-slate-600 hover:text-slate-900"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <div id="mobile-menu-backdrop" class="absolute inset-0 z-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div id="mobile-menu-panel" class="absolute right-0 top-0 z-10 h-full w-72 bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto">
      <div class="p-6">
        <button
          id="mobile-menu-close"
          class="absolute top-5 right-5 p-2 text-slate-500 hover:text-slate-900"
          aria-label="Close menu"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <nav class="mt-12 flex flex-col gap-1" aria-label="Mobile navigation">
          <!-- Platform (expandable) -->
          <details class="group/platform">
            <summary class:list={[
              'flex items-center justify-between px-4 py-3 text-base font-medium rounded-xl transition-colors cursor-pointer list-none',
              currentPath.startsWith('/platform')
                ? 'text-blue-600 bg-blue-50'
                : 'text-slate-700 hover:bg-slate-50',
            ]}>
              <span>Platform</span>
              <svg class="w-4 h-4 transition-transform duration-200 group-open/platform:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="ml-4 mt-1 flex flex-col gap-0.5 pb-2">
              {platformLinks.map(({ label, href }) => (
                <a
                  href={href}
                  class="block px-4 py-2 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors"
                >
                  {label}
                </a>
              ))}
              <a
                href={platformFeatured.href}
                class="block px-4 py-2 text-sm font-medium text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
              >
                {platformFeatured.label}
              </a>
            </div>
          </details>

          <!-- Solutions (expandable) -->
          <details class="group/solutions">
            <summary class:list={[
              'flex items-center justify-between px-4 py-3 text-base font-medium rounded-xl transition-colors cursor-pointer list-none',
              currentPath.startsWith('/solutions')
                ? 'text-blue-600 bg-blue-50'
                : 'text-slate-700 hover:bg-slate-50',
            ]}>
              <span>Solutions</span>
              <svg class="w-4 h-4 transition-transform duration-200 group-open/solutions:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="ml-4 mt-1 flex flex-col gap-0.5 pb-2">
              {solutionsLinks.map(({ label, href }) => (
                <a
                  href={href}
                  class="block px-4 py-2 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors"
                >
                  {label}
                </a>
              ))}
            </div>
          </details>

          <!-- Flat Links -->
          {flatLinks.map(({ label, href }) => (
            <a
              href={href}
              class:list={[
                'block px-4 py-3 text-base font-medium rounded-xl transition-colors',
                currentPath.startsWith(href)
                  ? 'text-blue-600 bg-blue-50'
                  : 'text-slate-700 hover:bg-slate-50',
              ]}
            >
              {label}
            </a>
          ))}
        </nav>

        <div class="mt-8 flex flex-col gap-3 px-4">
          <a
            href="https://app.brittani.ai/sign-in"
            class="text-center text-sm font-medium text-slate-700 py-3 border border-slate-200 rounded-xl hover:border-blue-600 transition-colors"
          >
            Log In
          </a>
          <a
            href="https://app.brittani.ai/sign-up"
            class="text-center text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 py-3 rounded-xl transition-all duration-200"
          >
            Request Demo
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-18"></div>

<script>
  // Header scroll effect
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 10) {
        header.classList.add('backdrop-blur-lg', 'bg-white/80', 'border-b', 'border-slate-200', 'shadow-sm');
      } else {
        header.classList.remove('backdrop-blur-lg', 'bg-white/80', 'border-b', 'border-slate-200', 'shadow-sm');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Desktop dropdown hover-intent
  const dropdowns = document.querySelectorAll('[data-dropdown]');
  dropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector('.dropdown-trigger') as HTMLButtonElement;
    const panel = dropdown.querySelector('.dropdown-panel') as HTMLElement;
    const chevron = dropdown.querySelector('.dropdown-chevron') as SVGElement;
    let hideTimeout: ReturnType<typeof setTimeout> | null = null;

    function show() {
      if (hideTimeout) {
        clearTimeout(hideTimeout);
        hideTimeout = null;
      }
      // Close other dropdowns
      dropdowns.forEach((other) => {
        if (other !== dropdown) {
          const otherPanel = other.querySelector('.dropdown-panel') as HTMLElement;
          const otherTrigger = other.querySelector('.dropdown-trigger') as HTMLButtonElement;
          const otherChevron = other.querySelector('.dropdown-chevron') as SVGElement;
          if (otherPanel) {
            otherPanel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
            otherPanel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
          }
          if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
          if (otherChevron) otherChevron.classList.remove('rotate-180');
        }
      });
      if (panel) {
        panel.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
        panel.classList.add('opacity-100', 'visible', 'pointer-events-auto');
      }
      if (trigger) trigger.setAttribute('aria-expanded', 'true');
      if (chevron) chevron.classList.add('rotate-180');
    }

    function hide() {
      hideTimeout = setTimeout(() => {
        if (panel) {
          panel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          panel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
        }
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.classList.remove('rotate-180');
      }, 150);
    }

    // Mouse events
    dropdown.addEventListener('mouseenter', show);
    dropdown.addEventListener('mouseleave', hide);

    // Keyboard: toggle on click/enter
    trigger?.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        hide();
        if (hideTimeout) {
          clearTimeout(hideTimeout);
          hideTimeout = null;
        }
        // Immediate hide for click
        if (panel) {
          panel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          panel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
        }
        trigger.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.classList.remove('rotate-180');
      } else {
        show();
      }
    });

    // Focus within keeps panel open
    dropdown.addEventListener('focusin', show);
    dropdown.addEventListener('focusout', (e) => {
      const related = (e as FocusEvent).relatedTarget as Node | null;
      if (!dropdown.contains(related)) {
        hide();
      }
    });
  });

  // Escape closes all dropdowns
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      dropdowns.forEach((dropdown) => {
        const panel = dropdown.querySelector('.dropdown-panel') as HTMLElement;
        const trigger = dropdown.querySelector('.dropdown-trigger') as HTMLButtonElement;
        const chevron = dropdown.querySelector('.dropdown-chevron') as SVGElement;
        if (panel) {
          panel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          panel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
        }
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.classList.remove('rotate-180');
      });
      // Also close mobile menu
      closeMenu();
    }
  });

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');
  const menuBackdrop = document.getElementById('mobile-menu-backdrop');
  const menuPanel = document.getElementById('mobile-menu-panel');

  function openMenu() {
    if (!menu || !menuPanel || !menuBtn) return;
    menu.classList.remove('hidden');
    menuBtn.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => {
      menuPanel.classList.remove('translate-x-full');
    });
  }

  function closeMenu() {
    if (!menu || !menuPanel || !menuBtn) return;
    menuPanel.classList.add('translate-x-full');
    menuBtn.setAttribute('aria-expanded', 'false');
    setTimeout(() => {
      menu.classList.add('hidden');
    }, 300);
  }

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  menuBackdrop?.addEventListener('click', closeMenu);
</script>

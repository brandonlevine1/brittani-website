---
import '../styles/global.css';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  noindex = false,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://brittani.ai';
const canonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Google Analytics 4 — set PUBLIC_GA4_ID (e.g. G-XXXXXXXXXX) in the build env.
// When unset (local/dev), the tag is omitted entirely.
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/logo-mark-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: fullOgImage,
          url: canonicalUrl,
        },
        optional: {
          description: description,
          siteName: 'Brittani AI',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        site: '@britanniai',
        creator: '@britanniai',
      }}
    />

    {jsonLd && (
      Array.isArray(jsonLd) ? (
        jsonLd.map((schema) => (
          <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        ))
      ) : (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    )}
    <slot name="head" />

    {ga4Id && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ${JSON.stringify(ga4Id)});
        `}></script>
      </Fragment>
    )}
  </head>
  <body class="bg-white text-slate-900 font-sans">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-blue-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-xl focus:text-sm focus:font-semibold"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>

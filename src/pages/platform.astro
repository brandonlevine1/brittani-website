---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneMockup from '../components/platform/PhoneMockup.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://brittani.ai" },
    { "@type": "ListItem", "position": 2, "name": "Platform", "item": "https://brittani.ai/platform" }
  ]
};

const valuePillars = [
  {
    title: 'Close More, Coordinate Zero',
    description: 'Every email, follow-up, and deadline handled — you just sell.',
    icon: 'target',
  },
  {
    title: 'Zero Missed Deadlines',
    description: 'Automatic tracking across every party, every date, every deal.',
    icon: 'clock',
  },
  {
    title: 'Your Email, Your Relationships',
    description: "Sends from your real address — title companies and lenders trust it because it's you.",
    icon: 'mail',
  },
];

const platformModules = [
  {
    name: 'Contract Intelligence',
    description: 'Upload a PDF. Get every date, dollar, and defect — in seconds.',
    icon: 'file-scan',
  },
  {
    name: 'Communications Engine',
    description: 'Every party gets the right email at the right time. From your real address. You never hit send.',
    icon: 'send',
  },
  {
    name: 'Deadline System',
    description: 'Every contingency, every inspection deadline, every closing date — tracked and reminded automatically.',
    icon: 'calendar-check',
  },
  {
    name: 'Deal Command Center',
    description: 'Every deal running. One place to prove it.',
    icon: 'layout-dashboard',
  },
  {
    name: 'Coordination Agents',
    description: 'Inspection scheduling, lender follow-ups, title status — handled.',
    icon: 'users',
  },
  {
    name: 'Brittani Agent (SMS + Chat)',
    description: 'Text from your car. Get deal answers, approve emails, check deadlines — no app, no login, no dashboard.',
    icon: 'smartphone',
  },
];

const architectureSteps = [
  'Upload Contract',
  'Dates & Terms Extracted',
  'All Parties Notified',
  'Replies Monitored',
  'Deal Closes',
];

const securityBullets = [
  'Encrypted credentials — your email keys never leave our vault',
  'Isolated data per brokerage — no cross-contamination, ever',
  'Every action logged — full audit trail for compliance',
  'Google security-audited (CASA) — verified for restricted OAuth scopes',
];
---

<PageLayout
  title="Platform — Transaction Coordination That Does The Work | Brittani AI"
  description="See how Brittani coordinates every email, deadline, and follow-up from contract to close — autonomously, from your real email address."
  canonical="https://brittani.ai/platform"
  jsonLd={breadcrumbSchema}
>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO — Dark -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-slate-900 py-24 md:py-32 lg:py-40">
    <!-- Ambient glow -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-40 left-1/3 w-[600px] h-[600px] bg-blue-600/20 rounded-full blur-[120px]"></div>
      <div class="absolute -bottom-20 right-1/4 w-[400px] h-[400px] bg-violet-600/15 rounded-full blur-[100px]"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 md:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-blue-400 mb-4">The Platform</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-white leading-[1.1]">
        It Runs Your Deals.<br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-blue-400 to-violet-400 bg-clip-text text-transparent">You Close Them.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
        From contract to close, Brittani coordinates every email, every deadline, every follow-up — so you never touch admin again.
      </p>
      <div class="mt-10">
        <a
          href="#"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl text-base transition-all duration-200 hover:shadow-lg hover:shadow-blue-600/25"
        >
          Request a Demo
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- VALUE PILLARS -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">Why Brittani</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          Built for agents who refuse to be their own TC
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        {valuePillars.map((pillar) => (
          <div class="text-center md:text-left">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-50 border border-blue-100 mb-5">
              {pillar.icon === 'target' && (
                <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" />
                </svg>
              )}
              {pillar.icon === 'clock' && (
                <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
                </svg>
              )}
              {pillar.icon === 'mail' && (
                <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="4" width="20" height="16" rx="2" /><path d="M22 7l-10 6L2 7" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">{pillar.title}</h3>
            <p class="text-slate-600 leading-relaxed">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- PROOF METRICS -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-20 bg-slate-50 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-slate-900">10+</div>
          <div class="mt-1 text-sm text-slate-600">Hours saved per deal</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-slate-900">0</div>
          <div class="mt-1 text-sm text-slate-600">Missed deadlines</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-slate-900">100%</div>
          <div class="mt-1 text-sm text-slate-600">Sent from your email</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-slate-900">24/7</div>
          <div class="mt-1 text-sm text-slate-600">Always coordinating</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- PLATFORM MODULES -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">Platform Modules</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          Six systems. One autonomous coordinator.
        </h2>
        <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
          Each module works independently — and together, they run your entire transaction.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {platformModules.map((mod, i) => (
          <div class={`group border border-slate-200 rounded-2xl p-8 transition-all duration-200 hover:shadow-lg hover:border-blue-200 ${i === 5 ? 'md:col-span-2 lg:col-span-1' : ''}`}>
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-blue-50 border border-blue-100 mb-5 group-hover:bg-blue-100 transition-colors">
              {mod.icon === 'file-scan' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><path d="M14 2v6h6" /><path d="M16 13H8M16 17H8M10 9H8" />
                </svg>
              )}
              {mod.icon === 'send' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
                </svg>
              )}
              {mod.icon === 'calendar-check' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /><path d="M9 16l2 2 4-4" />
                </svg>
              )}
              {mod.icon === 'layout-dashboard' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="7" height="9" rx="1" /><rect x="14" y="3" width="7" height="5" rx="1" /><rect x="14" y="12" width="7" height="9" rx="1" /><rect x="3" y="16" width="7" height="5" rx="1" />
                </svg>
              )}
              {mod.icon === 'users' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                </svg>
              )}
              {mod.icon === 'smartphone' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="5" y="2" width="14" height="20" rx="2" /><path d="M12 18h.01" />
                </svg>
              )}
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{mod.name}</h3>
            <p class="text-slate-600 leading-relaxed text-sm">{mod.description}</p>

            {/* Phone mockup for SMS module */}
            {i === 5 && (
              <div class="mt-8">
                <PhoneMockup />
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- ARCHITECTURE VISUAL -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          From upload to close — fully autonomous
        </h2>
      </div>

      <!-- Flow diagram -->
      <div class="relative max-w-5xl mx-auto">
        <!-- Desktop: horizontal flow -->
        <div class="hidden lg:flex items-center justify-between">
          {architectureSteps.map((step, i) => (
            <div class="flex items-center">
              <div class="flex flex-col items-center">
                <div class="w-14 h-14 rounded-full bg-white border-2 border-blue-200 flex items-center justify-center shadow-sm">
                  <span class="text-sm font-bold text-blue-600">{i + 1}</span>
                </div>
                <span class="mt-3 text-sm font-medium text-slate-700 text-center max-w-[120px]">{step}</span>
              </div>
              {i < architectureSteps.length - 1 && (
                <div class="mx-3 flex-shrink-0">
                  <svg class="w-6 h-6 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Mobile: vertical flow -->
        <div class="lg:hidden space-y-4">
          {architectureSteps.map((step, i) => (
            <div class="flex items-center gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-white border-2 border-blue-200 flex items-center justify-center shadow-sm">
                <span class="text-sm font-bold text-blue-600">{i + 1}</span>
              </div>
              <span class="text-sm font-medium text-slate-700">{step}</span>
            </div>
          ))}
        </div>

        <!-- Agent layer -->
        <div class="mt-12 border-t-2 border-dashed border-blue-200 pt-8">
          <div class="flex items-center justify-center gap-3 bg-white border border-blue-200 rounded-2xl py-4 px-6 max-w-md mx-auto shadow-sm">
            <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="5" y="2" width="14" height="20" rx="2" /><path d="M12 18h.01" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-bold text-slate-900">Brittani Agent</div>
              <div class="text-xs text-slate-500">Always-on access via SMS or chat — at any step</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- INTEGRATIONS -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">Integrations</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          Works with the tools you already use
        </h2>
      </div>

      <!-- Active integrations -->
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8 mb-8">
        <div class="bg-white border-2 border-slate-200 rounded-2xl px-8 py-6 flex items-center gap-3 hover:border-blue-300 hover:shadow-md transition-all">
          <svg class="w-6 h-6 text-red-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 010 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>
          </svg>
          <span class="text-lg font-semibold text-slate-700">Gmail</span>
        </div>
        <div class="bg-white border-2 border-slate-200 rounded-2xl px-8 py-6 flex items-center gap-3 hover:border-blue-300 hover:shadow-md transition-all">
          <svg class="w-6 h-6 text-blue-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="text-lg font-semibold text-slate-700">Google Workspace</span>
        </div>
      </div>

      <!-- Coming soon -->
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8">
        <div class="bg-slate-50 border border-dashed border-slate-300 rounded-2xl px-8 py-6 flex items-center gap-3">
          <span class="text-lg font-semibold text-slate-400">Outlook</span>
          <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">Coming Soon</span>
        </div>
        <div class="bg-slate-50 border border-dashed border-slate-300 rounded-2xl px-8 py-6 flex items-center gap-3">
          <span class="text-lg font-semibold text-slate-400">DocuSign</span>
          <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">Coming Soon</span>
        </div>
        <div class="bg-slate-50 border border-dashed border-slate-300 rounded-2xl px-8 py-6 flex items-center gap-3">
          <span class="text-lg font-semibold text-slate-400">MLS</span>
          <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECURITY & TRUST -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="max-w-3xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-400 mb-3">Security & Trust</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
          It acts on your behalf — so security is foundational, not optional.
        </h2>

        <div class="mt-10 space-y-5">
          {securityBullets.map((bullet) => (
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 mt-1">
                <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <p class="text-slate-300 leading-relaxed">{bullet}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 flex items-center gap-6">
          <div class="flex items-center gap-2 text-sm text-slate-400">
            <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            SOC 2 Type II (in progress)
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-400">
            <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            CASA Verified
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- FINAL CTA -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900">
        See what it looks like when your deals coordinate themselves.
      </h2>
      <div class="mt-10">
        <a
          href="#"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl text-base transition-all duration-200 hover:shadow-lg hover:shadow-blue-600/25"
        >
          Request a Demo
        </a>
      </div>
    </div>
  </section>

</PageLayout>

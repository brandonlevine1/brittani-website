---
import PageLayout from '../../../layouts/PageLayout.astro';
import CTABanner from '../../../components/global/CTABanner.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  const hubs = [
    { slug: 'seller-disclosure-requirements', title: 'Seller Disclosure Requirements by State', description: 'State-by-state seller disclosure laws, forms, and compliance requirements for real estate agents — updated for 2026.' },
    { slug: 'agency-disclosure-requirements', title: 'Agency Disclosure Requirements by State', description: 'Agency disclosure rules and forms every agent must follow in each state — updated for 2026.' },
    { slug: 'lead-paint-disclosure', title: 'Lead Paint Disclosure Requirements by State', description: 'Federal and state lead paint disclosure rules, forms, and exemptions for residential real estate transactions.' },
    { slug: 'property-condition-disclosures', title: 'Property Condition & Environmental Disclosures by State', description: 'State requirements for disclosing property defects, environmental hazards, and material facts.' },
    { slug: 'hoa-condo-requirements', title: 'HOA & Condo Disclosure Rules by State', description: 'HOA document delivery timelines, condo resale certificates, and buyer cancellation rights in every state.' },
    { slug: 'buyer-agency-agreement-requirements', title: 'Buyer Agency Agreement Requirements by State', description: 'Post-NAR settlement buyer agency agreement rules, forms, and compliance requirements by state.' },
    { slug: 'commission-structure-changes', title: 'Commission Structure Rules After the NAR Settlement', description: 'How commission rules changed after the 2024 NAR settlement — state-by-state requirements for buyer and seller agents.' },
    { slug: 'earnest-money-rules', title: 'Earnest Money & Escrow Laws by State', description: 'Earnest money deposit rules, escrow holder requirements, and dispute resolution procedures in each state.' },
    { slug: 'buyer-contingency-deadlines', title: 'Buyer Contingency Deadlines by State', description: 'Default contingency periods for inspection, financing, and appraisal in residential contracts by state.' },
    { slug: 'dual-agency-rules', title: 'Dual Agency & Designated Agency Rules by State', description: 'Which states allow dual agency, designated agency requirements, and disclosure obligations for agents.' },
    { slug: 'wire-fraud-prevention', title: 'Wire Fraud Prevention Requirements by State', description: 'State and federal wire fraud prevention rules, disclosure requirements, and best practices for closings.' },
    { slug: 'who-pays-closing-costs', title: 'Who Pays Closing Costs by State — Buyer vs. Seller', description: 'Customary closing cost splits between buyers and sellers in each state, including transfer taxes and title fees.' },
    { slug: 'transfer-tax-recording-fees', title: 'Transfer Tax & Recording Fee Schedules by State', description: 'Current transfer tax rates, recording fees, and documentary stamp costs for residential transactions in every state.' },
    { slug: 'attorney-vs-title-company', title: 'Attorney vs. Title Company States — Who Must Be at Closing', description: 'Which states require an attorney at closing vs. title company only, and what that means for transaction coordination.' },
    { slug: 'title-and-closing-procedures', title: 'Title & Closing Procedures by State', description: 'Title search requirements, closing procedures, and settlement practices that vary by state.' },
    { slug: 'license-reciprocity-portability', title: 'Real Estate License Reciprocity & Portability by State', description: 'Which states have reciprocal licensing agreements, portability compacts, and what agents need to practice across borders.' },
    { slug: 'continuing-education-requirements', title: 'Continuing Education Requirements by State', description: 'CE hour requirements, renewal deadlines, and approved course topics for real estate license renewal in each state.' },
    { slug: 'teams-supervision-rules', title: 'Teams & Supervision Rules by State', description: 'State rules for real estate teams, broker supervision requirements, and team advertising compliance.' },
    { slug: 'commission-and-licensing-rules', title: 'Commission & Licensing Rules by State', description: 'Commission payment rules, referral fee regulations, and licensing requirements by state.' },
    { slug: 'firpta-withholding-rules', title: 'FIRPTA Withholding Rules for Foreign Sellers by State', description: 'Federal FIRPTA withholding requirements plus state-level withholding rules for foreign property sellers.' },
    { slug: '1031-exchange-rules', title: '1031 Exchange State Tax Implications', description: 'State income tax treatment of 1031 exchanges, clawback provisions, and reporting requirements.' },
    { slug: 'building-code-updates', title: 'Building Code Updates by State', description: 'Recent residential building code changes, effective dates, and what agents need to know about new construction.' },
    { slug: 'new-real-estate-laws', title: 'New Real Estate Laws by State', description: 'Newly enacted real estate legislation by state — bills signed into law affecting agents, brokers, and transactions.' },
    { slug: 'escrow-regulations', title: 'Escrow Regulations by State', description: 'Escrow account rules, interest requirements, and disbursement timelines for real estate transactions by state.' },
  ];
  return hubs.map(hub => ({
    params: { topic: hub.slug },
    props: { hub },
  }));
}

const { hub } = Astro.props;

const allPosts = await getCollection('blog');
const topicPosts = allPosts
  .filter(p => (p.data.tags || []).includes(hub.slug) || p.id.includes(hub.slug))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const stateNames = topicPosts.map(p => {
  const slug = p.id;
  const stateSlug = slug.replace(`-${hub.slug}-2026`, '').replace(`-${hub.slug}`, '');
  const name = stateSlug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
  return { name, postId: p.id, title: p.data.title, description: p.data.description };
}).sort((a, b) => a.name.localeCompare(b.name));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://brittani.ai" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://brittani.ai/blog" },
    { "@type": "ListItem", "position": 3, "name": hub.title, "item": `https://brittani.ai/blog/topic/${hub.slug}` }
  ]
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": hub.title,
  "description": hub.description,
  "url": `https://brittani.ai/blog/topic/${hub.slug}`,
  "numberOfItems": topicPosts.length,
  "publisher": {
    "@type": "Organization",
    "name": "Britanni AI",
    "url": "https://brittani.ai"
  }
};
---

<PageLayout
  title={`${hub.title} (2026) | Britanni AI`}
  description={hub.description}
  canonical={`https://brittani.ai/blog/topic/${hub.slug}`}
  jsonLd={[breadcrumbSchema, collectionSchema]}
>
  <section class="bg-gradient-to-br from-blue-50 via-violet-50/50 to-white py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <nav class="text-sm text-slate-400 mb-6">
        <a href="/blog" class="hover:text-blue-600 transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-slate-500">Topic Guide</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-slate-900">
        {hub.title}
      </h1>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">
        {hub.description}
      </p>
      <p class="mt-4 text-sm text-slate-400">
        {topicPosts.length} state guides published
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6 md:px-8">
      {topicPosts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {stateNames.map(({ name, postId, title, description }) => (
            <a
              href={`/blog/${postId}`}
              class="block p-5 rounded-xl border border-slate-200 hover:border-blue-300 hover:bg-blue-50/50 transition-all group"
            >
              <h2 class="text-base font-semibold text-slate-900 group-hover:text-blue-700 transition-colors">
                {name}
              </h2>
              <p class="mt-1 text-sm text-slate-500 line-clamp-2">{description}</p>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-slate-500 text-lg">Guides for this topic are being published daily. Check back soon.</p>
          <a href="/blog" class="mt-4 inline-block text-blue-600 hover:text-blue-700 font-medium text-sm">
            &larr; Back to all articles
          </a>
        </div>
      )}
    </div>
  </section>

  <CTABanner
    headline="Automate Compliance Tracking Across Every State"
    subheadline="Britanni AI monitors state-specific deadlines and requirements for every deal in your pipeline."
    primaryCta="Start Free Trial"
    secondaryCta="See Pricing"
  />
</PageLayout>

---
import PageLayout from '../../layouts/PageLayout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://brittani.ai"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Solutions",
      "item": "https://brittani.ai/solutions"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "For Agents",
      "item": "https://brittani.ai/solutions/agents"
    }
  ]
};

const painCards = [
  "It's 11pm. You're sending follow-up emails because the day was consumed by showings. There has to be a better way.",
  "One missed inspection deadline doesn't just cost this deal — it costs the next five referrals.",
  "At 10 deals/month, that's $4,000/month walking out the door to human TCs. And they still take vacations."
];

const howItWorks = [
  { title: "Deal Launch", description: "Upload contract, enter parties, click launch. Full automation in 60 seconds." },
  { title: "Party Communications", description: "Intro emails, status updates, and reminders sent from YOUR email address." },
  { title: "Deadline Protection", description: "Every date extracted, every reminder scheduled. Cannot miss." },
  { title: "Inspection Coordination", description: "Multi-party scheduling via email. No phone tag." },
  { title: "Lender & Title Follow-ups", description: "Weekly automated status checks. You know before your client asks." },
  { title: "Inbound Intelligence", description: "AI reads replies, classifies status updates, flags what needs your attention." },
  { title: "Brittani via SMS", description: "Text from your car. Check deadlines, approve emails, get deal summaries. The only TC that works from a text thread." }
];
---

<PageLayout
  title="Brittani AI for Individual Agents — Close More Deals, Coordinate Zero"
  description="Every email, every deadline, every follow-up — handled by AI. Brittani AI is the always-on transaction coordinator that lets you focus on revenue."
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-blue-400 mb-3">For Individual Agents</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
        Close More Deals. Coordinate Zero.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
        Every email, every deadline, every follow-up — handled. You focus on what generates revenue.
      </p>
      <div class="mt-10">
        <a
          href="https://app.brittani.ai/sign-up"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl transition-colors"
        >
          Sign Up Now
        </a>
      </div>
    </div>
  </section>

  <!-- The Pain -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">The Reality</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          Sound Familiar?
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {painCards.map((card) => (
          <div class="border border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <p class="text-slate-700 text-lg leading-relaxed italic">"{card}"</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-50">
    <div class="max-w-3xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          One Deal. Seven Automations.
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          From contract upload to closing — every step coordinated automatically.
        </p>
      </div>

      <div class="space-y-4">
        {howItWorks.map((item, index) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-6 text-left font-semibold text-slate-900 hover:bg-white transition-colors [&::-webkit-details-marker]:hidden list-none">
              <span>
                <span class="text-blue-600 mr-3">{String(index + 1).padStart(2, '0')}</span>
                {item.title}
              </span>
              <svg
                class="w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-slate-600 leading-relaxed">
              {item.description}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Aha Moment -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-6 md:px-8">
      <div class="bg-slate-50 border-l-4 border-blue-600 p-8 md:p-12 rounded-r-2xl">
        <p class="italic text-lg md:text-xl text-slate-700 leading-relaxed">
          "You're pulling into a listing appointment. Your buyer's agent just texted asking about the inspection deadline. You text Brittani: 'inspection deadline 123 Oak St.' Three seconds later, you have the answer. No login. No app. Just the answer — from your car."
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-900 text-white">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        Start Your First Deal Free
      </h2>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        See what it feels like to have every deadline tracked, every email sent, and every follow-up handled — without lifting a finger.
      </p>
      <div class="mt-10">
        <a
          href="https://app.brittani.ai/sign-up"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl transition-colors"
        >
          Sign Up Now
        </a>
      </div>
    </div>
  </section>
</PageLayout>

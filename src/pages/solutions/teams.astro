---
import PageLayout from '../../layouts/PageLayout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://brittani.ai"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Solutions",
      "item": "https://brittani.ai/solutions"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "For Teams",
      "item": "https://brittani.ai/solutions/teams"
    }
  ]
};

const features = [
  {
    title: "Shared Workspace",
    description: "Every team member sees every deal. No more 'who's handling that?' — one shared view of all active transactions, deadlines, and communications."
  },
  {
    title: "Team Lead Oversight",
    description: "Monitor deal progress across your team without micromanaging. Get alerted when something needs your attention — not for every routine step."
  },
  {
    title: "Consistent Client Experience",
    description: "Every buyer and seller on your team gets the same professional communication cadence, regardless of which agent is running the deal."
  },
  {
    title: "One Subscription, Full Coverage",
    description: "No per-deal fees. No per-agent surprises. One team plan covers everyone — whether you close 20 deals this month or 50."
  }
];
---

<PageLayout
  title="Brittani AI for Teams — One AI TC for Your Entire Team"
  description="Team leads: stop assigning admin. Start assigning deals. Brittani AI gives your entire team shared TC automation with team lead oversight."
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-blue-400 mb-3">For Teams</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
        One AI TC for Your Entire Team
      </h1>
      <p class="mt-6 text-lg md:text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
        Team leads: stop assigning admin. Start assigning deals.
      </p>
      <div class="mt-10">
        <a
          href="https://app.brittani.ai/sign-up"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl transition-colors"
        >
          Sign Up Now
        </a>
      </div>
    </div>
  </section>

  <!-- How Teams Use Brittani -->
  <section class="py-20 md:py-28 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">How Teams Use Brittani</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          Coordination That Scales With Your Team
        </h2>
        <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
          Whether you're a duo or a 15-agent powerhouse, Brittani keeps every deal on track without adding admin overhead.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {features.map((item) => (
          <div class="border border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-bold text-slate-900 mb-3">{item.title}</h3>
            <p class="text-slate-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Team Lead Advantage -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-50">
    <div class="max-w-4xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 mb-3">The Team Lead Advantage</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
          Lead the Team. Not the Paperwork.
        </h2>
      </div>

      <div class="space-y-8">
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-1">
            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-slate-900">Onboard new agents in minutes, not weeks</h3>
            <p class="mt-1 text-slate-600">They join the workspace and immediately have access to the same TC automation as your top producer.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-1">
            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-slate-900">Spot problems before they become fires</h3>
            <p class="mt-1 text-slate-600">Deadline alerts and deal status roll up to the team lead automatically. You see the big picture without chasing updates.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-1">
            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-slate-900">Spend your time on growth, not admin delegation</h3>
            <p class="mt-1 text-slate-600">Stop being the team's TC manager. Brittani handles the coordination so you can focus on coaching, recruiting, and closing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 lg:py-32 bg-slate-900 text-white">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        Ready to Give Your Team a TC?
      </h2>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        One plan. Every agent covered. Every deal coordinated.
      </p>
      <div class="mt-10">
        <a
          href="https://app.brittani.ai/sign-up"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl transition-colors"
        >
          Sign Up Now
        </a>
      </div>
    </div>
  </section>
</PageLayout>
